{
  "name": "fairnote",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:native": "tsc --noEmit && vite build --mode native",
    "preview": "vite preview",
    "lint": "eslint src tests *.ts",
    "test": "vitest run",
    "test:e2e": "npm run build && playwright test",
    "check": "npm run lint && npm run test && npm run test:e2e",
    "cap:sync": "npm run build:native && cap sync android",
    "android:open": "cap open android",
    "android:debug": "npm run cap:sync && cd android && gradlew.bat assembleDebug",
    "android:bundle": "npm run cap:sync && cd android && gradlew.bat bundleRelease"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.0.1",
    "eslint": "^10.6.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/app": "^8.1.0",
    "@capacitor/camera": "^8.2.0",
    "@capacitor/core": "^8.4.1",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/network": "^8.0.1",
    "@capacitor/share": "^8.0.1",
    "jszip": "^3.10.1"
  }
}
